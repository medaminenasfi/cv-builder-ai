PORT=3002
NODE_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=55432
DATABASE_USER=cvbuilder
DATABASE_PASSWORD=cvbuilder
DATABASE_NAME=cvbuilder

JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_URL=redis://localhost:6379

FRONTEND_URL=http://localhost:3000

ADMIN_SETUP_SECRET=change-me-in-production
STRIPE_SECRET_KEY=sk_test_placeholder

# AI — OpenRouter (recommended). gemini-2.0-flash-001 was retired June 2026.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_TEMPLATE_MODEL=google/gemini-2.5-flash-lite
# CV chat / parse — keep low if credits are tight (default cap in code is 192)
OPENROUTER_MAX_TOKENS=192
# Template import needs much more output (HTML+CSS JSON)
OPENROUTER_TEMPLATE_MAX_TOKENS=2048
# Higher quality (more expensive): google/gemini-2.5-flash or google/gemini-3.5-flash

# Local file storage (exports + uploaded CV imports)
LOCAL_STORAGE_PATH=./storage
API_PUBLIC_URL=http://localhost:3002/api

# Or Anthropic direct (sk-ant-...) instead of OpenRouter
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
