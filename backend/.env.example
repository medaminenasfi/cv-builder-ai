PORT=3002
NODE_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=55432
DATABASE_USER=cvbuilder
DATABASE_PASSWORD=cvbuilder
DATABASE_NAME=cvbuilder

JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_URL=redis://localhost:6379

FRONTEND_URL=http://localhost:3000

ADMIN_SETUP_SECRET=change-me-in-production
STRIPE_SECRET_KEY=sk_test_placeholder

# AI template import — OpenRouter (recommended)
OPENROUTER_API_KEY=
# Optional; defaults to anthropic/claude-sonnet-4
OPENROUTER_MODEL=anthropic/claude-sonnet-4
# Optional; lower if you have limited OpenRouter credits (default 2048)
OPENROUTER_MAX_TOKENS=2048

# Or Anthropic direct (sk-ant-...) instead of OpenRouter
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
